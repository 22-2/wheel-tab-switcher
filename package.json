{
	"name": "wheel-tab-switcher",
	"version": "0.2.7",
	"description": "Switch between Obsidian tabs using your mouse wheel when hovering over tab headers",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.ext.mjs",
		"format": "biome format --write src/",
		"version:update": "node version-bump.ext.mjs update",
		"version:commit": "node version-bump.ext.mjs commit",
		"version:tag": "node version-bump.ext.mjs tag",
		"version:push": "node version-bump.ext.mjs push",
		"version:all": "node version-bump.ext.mjs all"
	},
	"keywords": [],
	"author": "22-2",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/node": "^25.9.1",
		"builtin-modules": "5.2.0",
		"esbuild": "0.28.0",
		"obsidian": "^1.12.3",
		"obsidian-typings": "^6.10.0",
		"typescript": "^6.0.3"
	}
}
