{
    "compilerOptions": {
        // Project structure
        "paths": {"*": ["./*"]},

        // Module system
        "module": "ESNext",
        "target": "ESNext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,

        // Type checking
        "strict": true,

        // Type definitions
        "types": ["node", "@obsidian-typings/obsidian-public-latest"],
        "lib": ["DOM", "ESNext"],
    },
    "include": ["src/**/*.ts", "./eslint.config.mts"],
    "exclude": ["node_modules"]
}
