{
	"compilerOptions": {
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"paths": {"*": ["./*"]},
		"lib": ["DOM", "ESNext"],
		"types": ["obsidian-typings"]
	},
	"include": ["**/*.ts"]
}
