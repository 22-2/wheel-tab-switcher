{
    "compilerOptions": {
        // Project structure
        "paths": {"*": ["./*"]},

        // Module system
        "module": "ESNext",
        "target": "ESNext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,

        // Type checking
        "strict": true,

        // Type definitions
        "types": ["obsidian-typings"],
        "lib": ["DOM", "ESNext"],
        "jsx": "react-jsx"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
}
